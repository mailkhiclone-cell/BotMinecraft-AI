{
  "name": "3d2y-bot-local",
  "version": "5.1.0",
  "description": "3D2Y Minecraft Bot – chạy local (bot + web console server)",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "PORT=8080 SERVE_STATIC=true NODE_ENV=production node server/dist/index.mjs",
    "start:3000": "PORT=3000 SERVE_STATIC=true NODE_ENV=production node server/dist/index.mjs",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.cjs"]
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "minecraft-data": "^3.110.2",
    "minecraft-protocol": "^1.66.2",
    "mineflayer": "^4.37.1",
    "mineflayer-collectblock": "^1.6.0",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-pvp": "^1.3.2",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "prismarine-nbt": "^2.6.1",
    "vec3": "^0.2.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2"
  }
}
